# Application
APP_NAME=Research Assistant Agent
APP_ENV=development
HOST=0.0.0.0
PORT=8000

# Database
RESEARCH_DB_URL=sqlite:///./data/research/research_assistant.db
PAPER_UPLOAD_DIR=./data/papers

# Models: compatible with OpenAI-style APIs
MAIN_MODEL=
MAIN_BASE_URL=
MAIN_API_KEY=

EXTRACTION_MODEL=
EXTRACTION_BASE_URL=
EXTRACTION_API_KEY=

JUDGE_MODEL=
JUDGE_BASE_URL=
JUDGE_API_KEY=

# Embedding and rerank
EMBEDDER=
EMBEDDER_BASE_URL=
EMBEDDER_API_KEY=

RERANK_MODEL=
RERANK_BINDING_HOST=
RERANK_API_KEY=

# Feature flags
GRAPH_RAG_LITE_ENABLED=true
MCP_ENABLED=false
EXTERNAL_LITERATURE_SEARCH_ENABLED=false
EXTERNAL_LITERATURE_PROVIDERS=openalex,arxiv,semantic_scholar
OPENALEX_BASE_URL=https://api.openalex.org
ARXIV_BASE_URL=https://export.arxiv.org/api/query
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1/paper/search
